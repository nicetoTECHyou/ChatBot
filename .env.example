# ============================================================
# StreamForge AI Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# ---- Server ----
PORT=3001
HOST=0.0.0.0

# ---- Admin Interface ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=streamforge

# ---- Twitch ----
TWITCH_USERNAME=streamforgebot
TWITCH_OAUTH_TOKEN=oauth:your_twitch_token_here
TWITCH_CHANNELS=your_channel_name
TWITCH_CLIENT_ID=your_client_id

# ---- Kick (Optional) ----
ENABLE_KICK=false
KICK_USERNAME=
KICK_OAUTH_TOKEN=
KICK_CHANNELS=

# ---- AI Providers ----
# LM Studio (Local - Default, always available)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen2.5-7b-instruct

# OpenAI (Optional - Cloud backup)
OPENAI_API_KEY=

# Anthropic (Optional - Premium)
ANTHROPIC_API_KEY=

# ---- AI Settings ----
AI_DEFAULT_PROVIDER=lmstudio
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=150
AI_RESPONSE_MAX_LENGTH=300
AI_RATE_LIMIT_PER_MINUTE=30

# ---- Chat ----
MAX_CHAT_HISTORY=40
BOT_COOLDOWN_MS=3000
SAME_USER_COOLDOWN_MS=10000
RESPONSE_PROBABILITY=0.8

# ---- Features ----
ENABLE_TWITCH=true
ENABLE_QUEST_SYSTEM=true
ENABLE_DEATH_COUNTER=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_PREDICTIVE_WELCOME=true
AUTO_PERSONA_SWITCH=true
SENTIMENT_PERSONA_SWITCH=true

# ---- Database ----
DB_PATH=./data/streamforge.db

# ---- Logging ----
LOG_LEVEL=info
